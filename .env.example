# ============ garimpo-pc-backend — variáveis de ambiente ============
# Copie para .env e preencha. NUNCA comite o .env real.

# --- Banco (Railway / Postgres local) ---
DATABASE_URL=postgresql://usuario:senha@host:5432/garimpo
# Em Railway o SSL é exigido. Em Postgres local deixe vazio/false.
DB_SSL=false

# --- Camada de IA pluggable ---
# Provider global. Valores: anthropic | openai
AI_PROVIDER=anthropic
# Overrides opcionais por tarefa (caem no global se vazios)
AI_PROVIDER_LOTE=
AI_PROVIDER_PARSER=
AI_PROVIDER_CALIBRADOR=

# Chaves dos providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Modelos (opcional — têm default no código)
# "dificil" = leitura difícil; "rapido" = lote/barato
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL_RAPIDO=claude-haiku-4-5-20251001
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_RAPIDO=gpt-4o-mini

# --- Imagens (opcional na Fase 1) ---
# Se vazio, prints não são enviados ao Cloudinary (calibração funciona mesmo assim).
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# --- Auth (token simples, single-user) ---
APP_TOKEN=troque-este-token

# --- Servidor ---
PORT=3001
